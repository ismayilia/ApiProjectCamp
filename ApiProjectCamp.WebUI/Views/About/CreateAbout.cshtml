@model CreateAboutDto

@{
    ViewData["Title"] = "CreateAbout";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<section class="section">
	<div class="section-body">
		<div class="row">
			<div class="col-12 col-md-12 col-lg-12">
				<div class="card">
					<div class="card-header">
						<h4>Create About Page</h4>
					</div>
					<div class="card-body">
						<form method="post">
							<label asp-for="Title">Title</label>
							<input type="text" asp-for="Title" class="form-control" />
							<br>
							<label asp-for="ReservationNumber">Reservation Number</label>
							<input type="text" asp-for="ReservationNumber" class="form-control" />
							<br>
							<label asp-for="ImageUrl">Image URL</label>
							<input type="text" asp-for="ImageUrl" class="form-control" />
							<br>
							<label asp-for="VideoCoverImageUrl">Video cover image</label>
							<input type="text" asp-for="VideoCoverImageUrl" class="form-control" />
							<br>
							<label asp-for="VideoUrl">Video URL (Embed Link)</label>
							<input type="text" asp-for="VideoUrl" class="form-control" />
							<br>
							<label asp-for="Description">Description</label>
							<textarea class="form-control" rows="5" asp-for="Description"></textarea>
							<br>
							<button class="btn btn-primary">Cretae Feature</button>
						</form>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>


